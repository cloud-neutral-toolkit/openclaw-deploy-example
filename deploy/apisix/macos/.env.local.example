APISIX_HTTP_PORT=9080
API_PUBLIC_HOST=api.svc.plus
LOCAL_API_HOST=127.0.0.1

OLLAMA_API_KEY=replace-me
OLLAMA_CHAT_ENDPOINT=https://ollama.com/v1/chat/completions
OLLAMA_CHAT_MODEL=glm-5:cloud
OLLAMA_MINIMAX_MODEL=minimax-m2.5:cloud
OLLAMA_KIMI_MODEL=kimi-k2.5:cloud

NVIDIA_API_KEY=replace-me
NVIDIA_CHAT_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_CHAT_MODEL=z-ai/glm5

KIMI_API_KEY=replace-me
KIMI_CHAT_ENDPOINT=https://api.moonshot.cn/v1/chat/completions
KIMI_CHAT_MODEL=kimi-k2.5:cloud

MINIMAX_API_KEY=replace-me
MINIMAX_CHAT_ENDPOINT=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_CHAT_MODEL=minimax-m2.5:cloud

EMBEDDINGS_API_KEY=replace-me
EMBEDDINGS_ENDPOINT=https://api.openai.com/v1/embeddings
EMBEDDINGS_MODEL=text-embedding-3-small

AI_GATEWAY_ACCESS_TOKEN=change-me-local-token

SYNC_REMOTE_HOST=root@openclaw.svc.plus
SYNC_REMOTE_DIR=/opt/svc-ai-gateway
SYNC_ONLINE_HOST=ai.svc.plus
